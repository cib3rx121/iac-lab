# Copy to terraform.tfvars and fill in real values (never commit terraform.tfvars).
#   cp terraform.tfvars.example terraform.tfvars
#
# Example network matches libvirt's default NAT (192.168.122.0/24, gateway .1).
# Replace IPs if your Proxmox or lab network differs (e.g. home LAN).

# Optional overrides (defaults in variables.tf): vm_id, proxmox_storage, network_bridge.

proxmox_api_token_secret = "REPLACE_WITH_TOKEN_SECRET"
proxmox_api_token_id     = "automation-user@pve!token-name"
proxmox_api_url          = "https://192.168.122.200:8006/api2/json"
proxmox_node             = "pve"
vm_template              = "ubuntu-2404-template"
vm_name                  = "k8s-master-01"
cloudinit_user           = "dev"
ssh_public_key           = "REPLACE_WITH_YOUR_SSH_PUBLIC_KEY_ONE_LINE"
master_ip_cidr           = "192.168.122.201/24"
master_gateway           = "192.168.122.1"
